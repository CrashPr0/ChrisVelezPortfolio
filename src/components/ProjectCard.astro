---
import type { Project } from "@/data/projects";
import TagPill from "@/components/TagPill.astro";
import { withBase } from "@/utils/paths";

type Props = {
  project: Project;
  showLink?: boolean;
};

const { project, showLink = true } = Astro.props;
---

<article class="project-card reveal">
  <div class="project-media-wrap">
    <img
      src={withBase(project.mediaPath)}
      alt={project.mediaAlt}
      class="project-media"
      loading="lazy"
      style={project.mediaFocus ? `object-position: ${project.mediaFocus};` : undefined}
    />
  </div>
  <div class="space-y-4 p-6">
    <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-wide text-slate-300">
      <span>{project.year}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>{project.role}</span>
    </div>
    <h3 class="font-display text-2xl text-white">{project.title}</h3>
    <p class="text-sm text-slate-300">{project.summary}</p>
    <p class="text-sm text-slate-200"><strong class="font-medium text-white/90">Impact:</strong> {project.impact}</p>
    <ul class="flex flex-wrap gap-2">
      {project.tags.map((tag) => <TagPill label={tag} />)}
    </ul>
    {
      showLink && (
        <a href={withBase(`/projects#${project.slug}`)} class="inline-flex text-sm font-medium text-accent-300 hover:text-accent-200">
          View case study
        </a>
      )
    }
  </div>
</article>
