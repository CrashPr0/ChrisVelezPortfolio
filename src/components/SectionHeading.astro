---
type Props = {
  kicker?: string;
  title: string;
  description?: string;
};

const { kicker, title, description } = Astro.props;
---

<div class="reveal max-w-3xl">
  {kicker && <p class="kicker">{kicker}</p>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="section-description">{description}</p>}
</div>
