---
import { withBase } from "@/utils/paths";

interface GalleryImage {
  src: string;
  alt: string;
  title?: string;
  span?: "wide" | "tall" | "default";
}

interface Props {
  title?: string;
  archiveHref?: string;
  archiveText?: string;
  images: GalleryImage[];
}

const {
  title = "Browse my work",
  archiveHref = "/projects",
  archiveText = "View all projects",
  images,
} = Astro.props;

// Assign bento spans: first wide, then alternate default/tall
const sized = images.map((img, i) => ({
  ...img,
  span: img.span ?? (i === 0 ? "wide" : i % 3 === 2 ? "tall" : "default"),
}));
---

<section aria-label={title} class="container py-16 md:py-20" id="portfolio-gallery">
  <!-- Header row -->
  <div class="flex items-end justify-between mb-8 gap-4">
    <div>
      <p class="kicker">Gallery</p>
      <h2 class="section-title">{title}</h2>
    </div>
    <a
      href={withBase(archiveHref)}
      class="group inline-flex shrink-0 items-center gap-2 rounded-full border border-white/10 bg-surface-800/60 px-5 py-2.5 text-xs font-semibold uppercase tracking-wider text-neutral-300 transition duration-200 hover:border-accent-400/40 hover:text-white hover:-translate-y-px active:scale-[0.98]"
      style="box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
    >
      {archiveText}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <!-- Bento grid -->
  <div class="bento-grid">
    {sized.map((image, i) => (
      <div
        class:list={[
          "bento-cell reveal",
          image.span === "wide" && "bento-wide",
          image.span === "tall" && "bento-tall",
        ]}
        style={`animation-delay: ${i * 60}ms`}
      >
        <div class="bento-inner group">
          <img
            src={withBase(image.src)}
            alt={image.alt}
            class="bento-img"
            loading={i < 2 ? "eager" : "lazy"}
            decoding="async"
          />
          {image.title && (
            <div class="bento-caption">
              <span>{image.title}</span>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 220px;
    gap: 0.75rem;
  }

  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .bento-wide { grid-column: span 2; }
    .bento-tall { grid-row: span 1; }
  }

  @media (min-width: 768px) {
    .bento-wide { grid-column: span 2; }
    .bento-tall { grid-row: span 2; }
  }

  .bento-cell {
    opacity: 0;
    animation: bento-in 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes bento-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .bento-inner {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgba(255,255,255,0.06);
    background: #141414;
    cursor: pointer;
    transition: border-color 0.25s ease, transform 0.25s cubic-bezier(0.16,1,0.3,1);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 20px 40px -15px rgba(0,0,0,0.5);
  }

  .bento-inner:hover {
    border-color: rgba(255,255,255,0.14);
    transform: translateY(-3px);
  }

  /* Spotlight border glow on hover */
  .bento-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(600px circle at var(--x, 50%) var(--y, 50%), rgba(58,210,242,0.08), transparent 60%);
    pointer-events: none;
  }

  .bento-inner:hover::after {
    opacity: 1;
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bento-inner:hover .bento-img {
    transform: scale(1.04);
  }

  .bento-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem;
    background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 100%);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .bento-inner:hover .bento-caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-cell { animation: none; opacity: 1; }
    .bento-inner, .bento-img { transition: none; }
  }
</style>

<script>
  // Track mouse position per cell for the spotlight effect
  document.querySelectorAll<HTMLElement>('.bento-inner').forEach((cell) => {
    cell.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = cell.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      cell.style.setProperty('--x', `${x}%`);
      cell.style.setProperty('--y', `${y}%`);
    });
  });
</script>
