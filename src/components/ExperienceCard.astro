---
import type { Experience } from "@/data/experience";

type Props = {
  item: Experience;
};

const { item } = Astro.props;
---

<article class="timeline-card reveal">
  <div class="timeline-dot" aria-hidden="true"></div>
  <div class="rounded-3xl border-2 border-white/10 bg-gradient-to-br from-white/[0.06] via-accent-500/[0.03] to-sky-500/[0.03] p-6 shadow-soft backdrop-blur-sm">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-display text-xl text-white">{item.title}</p>
        <p class="mt-1 text-sm font-bold text-accent-300">{item.company}</p>
      </div>
      <div class="text-right text-xs font-bold uppercase tracking-[0.1em] text-white/40">
        <p>{item.location}</p>
        <p>{item.dates}</p>
      </div>
    </div>
    <ul class="mt-5 space-y-3 text-sm text-white/65">
      {item.highlights.map((highlight) => <li class="timeline-bullet">{highlight}</li>)}
    </ul>
  </div>
</article>
