---
import type { Experience } from "@/data/experience";

type Props = {
  item: Experience;
};

const { item } = Astro.props;
---

<article class="timeline-card reveal">
  <div class="timeline-dot" aria-hidden="true"></div>
  <div class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-display text-lg font-bold text-white">{item.title}</p>
        <p class="mt-1 text-sm text-accent-400">{item.company}</p>
      </div>
      <div class="text-right text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
        <p>{item.location}</p>
        <p>{item.dates}</p>
      </div>
    </div>
    <ul class="mt-5 space-y-3 text-sm text-neutral-400">
      {item.highlights.map((highlight) => <li class="timeline-bullet">{highlight}</li>)}
    </ul>
  </div>
</article>
