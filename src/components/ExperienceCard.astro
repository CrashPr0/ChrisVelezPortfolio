---
import type { Experience } from "@/data/experience";

type Props = {
  item: Experience;
};

const { item } = Astro.props;
---

<article class="timeline-card reveal">
  <div class="timeline-dot" aria-hidden="true"></div>
  <div class="rounded-3xl border border-white/12 bg-white/5 p-6 shadow-soft backdrop-blur-sm">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-display text-xl text-white">{item.title}</p>
        <p class="mt-1 text-sm text-accent-300">{item.company}</p>
      </div>
      <div class="text-right text-xs uppercase tracking-[0.08em] text-slate-300">
        <p>{item.location}</p>
        <p>{item.dates}</p>
      </div>
    </div>
    <ul class="mt-5 space-y-3 text-sm text-slate-300">
      {item.highlights.map((highlight) => <li class="timeline-bullet">{highlight}</li>)}
    </ul>
  </div>
</article>
