---
import { navItems } from "@/data/site";
import { withBase } from "@/utils/paths";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 border-b border-accent-400/15 bg-surface-900/80 backdrop-blur-xl">
  <nav class="container flex items-center justify-between py-4" aria-label="Primary navigation">
    <a href={withBase("/")} class="font-display text-base tracking-wide text-accent-300 transition hover:text-accent-400">
      CV XR / SYSTEMS
    </a>
    <ul class="hidden gap-1 md:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              class={`nav-link ${isActive(item.href) ? "is-active" : ""}`}
              data-nav-link
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a href={withBase("/contact")} class="btn btn-sm md:hidden">
      Contact
    </a>
  </nav>
</header>
