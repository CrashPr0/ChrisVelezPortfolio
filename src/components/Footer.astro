---
import { siteConfig } from "@/data/site";
import { hrefFor } from "@/utils/paths";
---

<footer class="border-t border-accent-400/15 py-10">
  <div class="container flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-display text-lg text-accent-300">{siteConfig.name}</p>
      <p class="mt-2 max-w-lg text-sm text-white/50">
        Building immersive systems at the intersection of XR, graphics, and interactive technology.
      </p>
    </div>
    <ul class="flex flex-wrap gap-3 text-sm text-white/60">
      <li><a class="footer-link" href={hrefFor(siteConfig.github)} target="_blank" rel="noreferrer">GitHub</a></li>
      <li><a class="footer-link" href={hrefFor(siteConfig.linkedIn)} target="_blank" rel="noreferrer">LinkedIn</a></li>
      <li>
        <a class="footer-link" href={`mailto:${siteConfig.email}`}>
          {siteConfig.email}
        </a>
      </li>
    </ul>
  </div>
</footer>
