---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/paths";
---

<BaseLayout
  title="Experience | Christopher Velez"
  description="Professional experience in XR engineering, digital literacy, and immersive system deployment."
  currentPath="/experience"
>
  <head>
    <meta http-equiv="refresh" content={`0; url=${withBase("/resume")}`} />
  </head>
  <section class="container flex min-h-[60vh] flex-col items-start justify-center py-20">
    <p class="kicker">Redirect</p>
    <h1 class="hero-title max-w-3xl">Experience moved to Resume.</h1>
    <p class="mt-4 max-w-xl text-neutral-400">
      This page is now combined with the Resume page.
    </p>
    <div class="mt-8">
      <a href={withBase("/resume")} class="btn">Go to Resume</a>
    </div>
  </section>
</BaseLayout>
