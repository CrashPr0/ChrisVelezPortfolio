---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TagPill from "@/components/TagPill.astro";
import { education, skillGroups, siteConfig } from "@/data/site";
import { hrefFor } from "@/utils/paths";
---

<BaseLayout
  title="About | Christopher Velez"
  description="About Christopher Velez - Computer Engineering student specializing in AI-powered XR and immersive systems."
  currentPath="/about"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
      kicker="About"
      title="Engineer focused on future-facing spatial and interactive systems"
      description="I am a Computer Engineering student specializing in AI and XR technologies, building immersive systems for research, education, and public engagement."
    />
  </section>

  <section class="container grid gap-8 pb-20 lg:grid-cols-[1.1fr_1fr]">
    <article class="reveal rounded-4xl border border-white/[0.06] bg-surface-800/40 p-8">
      <h2 class="font-display text-2xl font-bold text-white">Professional Bio</h2>
      <div class="mt-5 space-y-4 text-sm leading-relaxed text-neutral-400">
        <p>
          Christopher is a student assistant at the King Library Experiential Virtual Reality Lab, where he builds immersive experiences that connect emerging technology with real-world impact.
        </p>
        <p>
          He has developed mobile WebAR experiences showcased to live audiences, work that was featured in the SJSU Spring 2026 Magazine, and serves as Graphics Lead on Benthos, a cooperative underwater exploration game in Unreal Engine.
        </p>
        <p>
          Outside the lab, he has facilitated drone coding workshops at community STEM events and led cultural preservation sessions teaching photogrammetry to indigenous communities.
        </p>
        <p>
          Whether he is prototyping AR navigation systems, pushing real-time graphics, or building AI tools to support students, Chris is drawn to work that makes complex technology feel approachable and purposeful.
        </p>
      </div>
      <img src={hrefFor(siteConfig.headshotPath)} alt="Christopher Velez headshot" class="mt-7 rounded-lg border border-white/[0.06]" />
    </article>

    <div class="space-y-8">
      <article class="reveal rounded-lg border border-white/[0.06] bg-surface-800/40 p-6">
        <h2 class="font-display text-lg font-bold text-white">Education</h2>
        <p class="mt-4 text-sm text-neutral-400">{education.university}</p>
        <p class="text-sm text-neutral-400">{education.degree}</p>
        <p class="mt-1 text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">{education.graduation}</p>
      </article>

      <article class="reveal rounded-lg border border-white/[0.06] bg-surface-800/40 p-6">
        <h2 class="font-display text-lg font-bold text-white">Skills</h2>
        <div class="mt-5 space-y-5">
          {Object.entries(skillGroups).map(([group, skills]) => (
            <section>
              <h3 class="mb-2 text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">{group}</h3>
              <div class="flex flex-wrap gap-2">
                {skills.map((skill) => <TagPill label={skill} />)}
              </div>
            </section>
          ))}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
