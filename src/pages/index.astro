---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { currentFocus, siteConfig } from "@/data/site";
import { projects } from "@/data/projects";
import { hrefFor, withBase } from "@/utils/paths";

const featuredProjects = projects.slice(0, 3);
---

<BaseLayout
  title="Christopher Velez | XR, Graphics, and Interactive Systems"
  description="Computer Engineering student building immersive XR, AR/VR, graphics, and interactive systems."
  currentPath="/"
>
  <section class="container pb-14 pt-16 md:pb-20 md:pt-24">
    <div class="hero-card reveal">
      <p class="kicker">Computer Engineering Student</p>
      <h1 class="hero-title">
        I&apos;m <span class="text-accent-300">Christopher Velez</span> &mdash; building the future of XR, graphics, and interactive systems.
      </h1>
      <p class="hero-subtitle">
        Immersive experiences across research, public engagement, and game development. Unity, Unreal, WebAR, photogrammetry, and whatever comes next.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={withBase("/projects")} class="btn">View Projects</a>
        <a href={hrefFor(siteConfig.resumePath)} class="btn btn-secondary" download>
          Download Resume
        </a>
      </div>
      <div class="focus-areas reveal mt-12 border-t border-accent-400/15 pt-10">
        <p class="focus-areas-label" id="focus-areas-heading">Currently focused on</p>
        <ul class="focus-areas-grid" aria-labelledby="focus-areas-heading">
          {
            currentFocus.map((item) => (
              <li class="focus-area-card">
                <span class="focus-area-accent" aria-hidden="true" />
                <span class="focus-area-text">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="container py-14 md:py-20" id="featured-projects">
    <SectionHeading
      kicker="Selected Work"
      title="Graphics, spatial systems, and public-facing XR"
      description="Game development, immersive demos, and community-centered technical work &mdash; all in one place."
    />
    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="container py-14 md:py-20">
    <SectionHeading
      kicker="Available For"
      title="Internships, research, and creative collaborations"
      description="XR prototyping, graphics pipelines, immersive experience engineering &mdash; let&apos;s build something amazing together."
    />
    <div class="reveal mt-7">
      <a href={withBase("/contact")} class="btn">
        Let&apos;s Connect
      </a>
    </div>
  </section>
</BaseLayout>
