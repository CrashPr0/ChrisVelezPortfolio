---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { currentFocus, siteConfig } from "@/data/site";
import { projects } from "@/data/projects";
import { hrefFor, withBase } from "@/utils/paths";

const featuredProjects = projects.slice(0, 3);
---

<BaseLayout
  title="Christopher Velez | XR, Graphics, and Interactive Systems"
  description="Computer Engineering student building immersive XR, AR/VR, graphics, and interactive systems."
  currentPath="/"
>
  <section class="container pb-14 pt-16 md:pb-20 md:pt-28">
    <div class="hero-card grid gap-10 md:grid-cols-[1fr_auto] md:items-start">
      <!-- Left: primary content -->
      <div>
        <p class="kicker hero-seq" style="animation-delay: 80ms">Computer Engineering · SJSU</p>
        <h1 class="hero-title" aria-label="Christopher Velez builds XR, graphics, and interactive systems.">
          <span class="hero-line hero-seq" style="animation-delay: 160ms">Christopher Velez</span>
          <span class="hero-line hero-seq" style="animation-delay: 260ms">builds XR, graphics,</span>
          <span class="hero-line hero-seq" style="animation-delay: 360ms">and interactive systems.</span>
        </h1>
        <p class="hero-subtitle hero-seq" style="animation-delay: 480ms">
          Immersive experiences across research, public engagement, and game development.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 hero-seq" style="animation-delay: 580ms">
          <a href={withBase("/projects")} class="btn">View Projects</a>
          <a href={hrefFor(siteConfig.resumePath)} class="btn btn-secondary" download>
            Download Resume
          </a>
        </div>
      </div>

      <!-- Right: focus areas -->
      <aside class="w-full md:w-64 lg:w-72" aria-labelledby="focus-areas-heading">
        <p class="focus-areas-label" id="focus-areas-heading">Focus</p>
        <ul class="mt-3 space-y-2 stagger-children">
          {currentFocus.map((item) => (
            <li class="focus-area-card">
              <span class="focus-area-accent" aria-hidden="true" />
              <span class="focus-area-text">{item}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <section class="container py-14 md:py-20" id="featured-projects">
    <SectionHeading
title="Graphics, spatial systems, and public-facing XR"
      description="Game development, immersive deployment, and community-centered technical work."
    />
    <div class="mt-10 grid gap-6 lg:grid-cols-3 stagger-children">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
    <div class="reveal mt-8">
      <a
        href={withBase("/projects")}
        class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-accent-400 hover:text-accent-300 hover:gap-2.5"
        style="transition: color 160ms ease, gap 160ms ease;"
      >
        All {projects.length} projects
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="container py-14 md:py-20">
    <SectionHeading
title="Internships, research, and collaboration"
      description="XR prototyping, graphics pipelines, and immersive experience engineering."
    />
    <div class="reveal mt-7">
      <a href={withBase("/contact")} class="btn">
        Start a conversation
      </a>
    </div>
  </section>
</BaseLayout>
