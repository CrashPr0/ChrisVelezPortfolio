---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ImageCarousel from "@/components/ImageCarousel.astro";
import TagPill from "@/components/TagPill.astro";
import { projects } from "@/data/projects";
import { withBase } from "@/utils/paths";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.title} | Christopher Velez`}
  description={project.summary}
  currentPath="/projects"
>
  <!-- Back link -->
  <div class="container pt-10 md:pt-14">
    <a
      href={withBase("/projects")}
      class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-neutral-500 hover:text-accent-400"
      style="transition: color 160ms ease;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      All Projects
    </a>
  </div>

  <!-- Hero -->
  <section class="container pb-10 pt-8 md:pt-12">
    <div class="mb-4 flex flex-wrap items-center gap-3 text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
      <span>{project.year}</span>
      <span class="h-1 w-1 rounded-full bg-neutral-600" aria-hidden="true"></span>
      <span>{project.role}</span>
    </div>
    <h1 class="font-display text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl">
      {project.title}
    </h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-neutral-400">{project.summary}</p>

    <!-- External links -->
    <div class="mt-6 flex flex-wrap gap-3">
      {project.githubUrl && (
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-white/10 bg-surface-800/60 px-4 py-2 text-sm font-medium text-neutral-300 hover:border-accent-400/40 hover:text-white"
          style="transition: border-color 160ms ease, color 160ms ease;">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23a11.52 11.52 0 0 1 3-.405c1.02.005 2.045.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      )}
      {project.steamUrl && (
        <a href={project.steamUrl} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-white/10 bg-surface-800/60 px-4 py-2 text-sm font-medium text-neutral-300 hover:border-accent-400/40 hover:text-white"
          style="transition: border-color 160ms ease, color 160ms ease;">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.029 4.524 4.524s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.455 1.012zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/>
          </svg>
          View on Steam
        </a>
      )}
      {project.pressUrl && (
        <a href={project.pressUrl} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-white/10 bg-surface-800/60 px-4 py-2 text-sm font-medium text-neutral-300 hover:border-accent-400/40 hover:text-white"
          style="transition: border-color 160ms ease, color 160ms ease;">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8M15 18h-5M10 6h8v4h-8z"/>
          </svg>
          Press Coverage
        </a>
      )}
      {project.siteUrl && (
        <a href={project.siteUrl} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-white/10 bg-surface-800/60 px-4 py-2 text-sm font-medium text-neutral-300 hover:border-accent-400/40 hover:text-white"
          style="transition: border-color 160ms ease, color 160ms ease;">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {project.siteLabel ?? "Visit Site"}
        </a>
      )}
    </div>
  </section>

  <!-- Media -->
  <section class="container pb-14">
    {project.mediaSlides && project.mediaSlides.length > 1 ? (
      <ImageCarousel slides={project.mediaSlides} focus={project.mediaFocus} id={project.slug} />
    ) : (
      <img
        src={withBase(project.mediaPath)}
        alt={project.mediaAlt}
        class="w-full rounded-xl object-cover"
        style={`aspect-ratio: 16/9; object-position: ${project.mediaFocus ?? "center"};`}
      />
    )}
  </section>

  <!-- Main content grid -->
  <section class="container pb-24 md:pb-32">
    <div class="grid gap-12 lg:grid-cols-[1fr_260px] lg:gap-16">

      <!-- Left: overview + process + challenges + lessons -->
      <div class="space-y-14">

        <!-- Overview -->
        <div class="reveal">
          <h2 class="font-display text-2xl font-extrabold tracking-tight text-white">Overview</h2>
          <p class="mt-3 text-neutral-300 leading-relaxed">{project.impact}</p>
          <div class="mt-4 space-y-3 text-sm leading-relaxed text-neutral-400">
            {project.description.map((p) => <p>{p}</p>)}
          </div>
        </div>

        <!-- Process -->
        {project.process && project.process.length > 0 && (
          <div class="reveal">
            <h2 class="font-display text-2xl font-extrabold tracking-tight text-white">Development Process</h2>
            <div class="mt-6 space-y-8">
              {project.process.map((step, i) => (
                <div class="flex gap-5">
                  <div class="flex-shrink-0 mt-1">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full border border-accent-400/40 bg-accent-400/10 text-xs font-bold text-accent-400">
                      {i + 1}
                    </span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-white">{step.heading}</h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-neutral-400">{step.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Challenges -->
        {project.challenges && project.challenges.length > 0 && (
          <div class="reveal">
            <h2 class="font-display text-2xl font-extrabold tracking-tight text-white">Challenges</h2>
            <ul class="mt-5 space-y-3">
              {project.challenges.map((c) => (
                <li class="flex gap-3 text-sm leading-relaxed text-neutral-400">
                  <span class="mt-[0.45em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent-400" aria-hidden="true"></span>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Lessons -->
        {project.lessons && project.lessons.length > 0 && (
          <div class="reveal">
            <h2 class="font-display text-2xl font-extrabold tracking-tight text-white">What I Learned</h2>
            <ul class="mt-5 space-y-3">
              {project.lessons.map((l) => (
                <li class="flex gap-3 text-sm leading-relaxed text-neutral-400">
                  <span class="mt-[0.45em] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent-400" aria-hidden="true"></span>
                  {l}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- Right: sidebar -->
      <aside class="space-y-6">
        <div class="reveal rounded-xl border border-white/[0.06] bg-surface-800/40 p-5">
          <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Role</p>
          <p class="mt-2 text-sm text-neutral-300">{project.role}</p>
        </div>
        <div class="reveal rounded-xl border border-white/[0.06] bg-surface-800/40 p-5">
          <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Year</p>
          <p class="mt-2 text-sm text-neutral-300">{project.year}</p>
        </div>
        <div class="reveal rounded-xl border border-white/[0.06] bg-surface-800/40 p-5">
          <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Tools</p>
          <p class="mt-2 text-sm text-neutral-400">{project.tools.join(" · ")}</p>
        </div>
        <div class="reveal rounded-xl border border-white/[0.06] bg-surface-800/40 p-5">
          <p class="mb-3 text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Tags</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => <TagPill label={tag} />)}
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Prev / Next navigation -->
  <nav class="container border-t border-white/[0.06] py-10" aria-label="Project navigation">
    <div class="flex items-center justify-between gap-4">
      {(() => {
        const idx = projects.findIndex((p) => p.slug === project.slug);
        const prev = projects[idx - 1];
        const next = projects[idx + 1];
        return (
          <>
            {prev ? (
              <a href={withBase(`/projects/${prev.slug}`)} class="group flex flex-col gap-1">
                <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-neutral-500 group-hover:text-accent-400" style="transition: color 160ms ease;">← Previous</span>
                <span class="text-sm font-medium text-neutral-300 group-hover:text-white" style="transition: color 160ms ease;">{prev.title}</span>
              </a>
            ) : <span />}
            {next ? (
              <a href={withBase(`/projects/${next.slug}`)} class="group flex flex-col items-end gap-1">
                <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-neutral-500 group-hover:text-accent-400" style="transition: color 160ms ease;">Next →</span>
                <span class="text-sm font-medium text-neutral-300 group-hover:text-white" style="transition: color 160ms ease;">{next.title}</span>
              </a>
            ) : <span />}
          </>
        );
      })()}
    </div>
  </nav>
</BaseLayout>
