---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TagPill from "@/components/TagPill.astro";
import { projects } from "@/data/projects";
import { withBase } from "@/utils/paths";
---

<BaseLayout
  title="Projects | Christopher Velez"
  description="Case studies in XR, graphics, and interactive systems by Christopher Velez."
  currentPath="/projects"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
      kicker="Projects"
      title="Case studies in immersive systems and interactive tech"
      description="Technical execution meets design intent meets real-world deployment."
    />
  </section>

  <section class="container flex flex-col gap-24 pb-24 md:gap-32 md:pb-28 lg:gap-40">
    {
      projects.map((project) => (
        <article id={project.slug} class="case-study reveal">
          <div class="case-grid">
            <div class="flex flex-col gap-8">
              <img
                src={withBase(project.mediaPath)}
                alt={project.mediaAlt}
                class="case-image"
                loading="lazy"
                style={project.mediaFocus ? `object-position: ${project.mediaFocus};` : undefined}
              />
              <div class="rounded-2xl border-2 border-accent-400/15 bg-gradient-to-r from-accent-500/10 to-sky-500/5 p-4">
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-sunny-300">Tools</p>
                <p class="mt-2 text-sm font-semibold text-white/70">{project.tools.join(" · ")}</p>
              </div>
            </div>
            <div>
              <div class="mb-5 flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-[0.1em] text-white/40">
                <span>{project.year}</span>
                <span class="dot" aria-hidden="true"></span>
                <span>{project.role}</span>
              </div>
              <h2 class="font-display text-3xl text-white">{project.title}</h2>
              <p class="mt-4 text-white/65">{project.summary}</p>
              <p class="mt-4 text-sm text-white/75">{project.impact}</p>
              <div class="mt-6 space-y-4 text-sm leading-relaxed text-white/60">
                {project.description.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="mt-6 flex flex-wrap gap-2">
                {project.tags.map((tag) => <TagPill label={tag} />)}
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
