---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TagPill from "@/components/TagPill.astro";
import ImageCarousel from "@/components/ImageCarousel.astro";
import { projects } from "@/data/projects";
import { withBase } from "@/utils/paths";
---

<BaseLayout
  title="Projects | Christopher Velez"
  description="Case studies in XR, graphics, and interactive systems by Christopher Velez."
  currentPath="/projects"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
title="Immersive systems and interactive technology"
      description="Technical execution, design intent, and real-world deployment."
    />
  </section>

  <section class="container flex flex-col pb-24 md:pb-28">
    {
      projects.map((project) => (
        <article id={project.slug} class="case-study reveal">
          <div class="case-grid">
            <div class="flex flex-col gap-8">
              {project.mediaSlides && project.mediaSlides.length > 1 ? (
                <ImageCarousel
                  slides={project.mediaSlides}
                  focus={project.mediaFocus}
                  id={project.slug}
                />
              ) : (
                <img
                  src={withBase(project.mediaPath)}
                  alt={project.mediaAlt}
                  class="case-image"
                  loading="lazy"
                  style={project.mediaFocus ? `object-position: ${project.mediaFocus};` : undefined}
                />
              )}
              <div class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-4">
                <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Tools</p>
                <p class="mt-2 text-sm text-neutral-400">{project.tools.join(" · ")}</p>
              </div>
            </div>
            <div>
              <div class="mb-4 flex flex-wrap items-center gap-3 text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
                <span>{project.year}</span>
                <span class="dot" aria-hidden="true"></span>
                <span>{project.role}</span>
              </div>
              <h2 class="font-display text-3xl font-extrabold tracking-tight text-white md:text-4xl">{project.title}</h2>
              <p class="mt-4 text-neutral-300">{project.summary}</p>
              <p class="mt-4 text-sm text-neutral-200">{project.impact}</p>
              <div class="mt-6 space-y-4 text-sm leading-relaxed text-neutral-400">
                {project.description.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="mt-8 flex flex-wrap gap-2">
                {project.tags.map((tag) => <TagPill label={tag} />)}
              </div>
              {project.githubUrl && (
                <div class="mt-6">
                  <a
                    href={project.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-md border border-white/10 bg-surface-800/60 px-4 py-2 text-sm font-medium text-neutral-300 transition hover:border-accent-400/40 hover:text-white"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23a11.52 11.52 0 0 1 3-.405c1.02.005 2.045.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
                    </svg>
                    View on GitHub
                  </a>
                </div>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
