---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TagPill from "@/components/TagPill.astro";
import { projects } from "@/data/projects";
import { withBase } from "@/utils/paths";
---

<BaseLayout
  title="Projects | Christopher Velez"
  description="Case studies in XR, graphics, and interactive systems by Christopher Velez."
  currentPath="/projects"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
      title="Immersive systems and interactive technology"
      description="Technical execution, design intent, and real-world deployment."
    />
  </section>

  <section class="container pb-24 md:pb-32">
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={withBase(`/projects/${project.slug}`)}
          class="reveal group flex flex-col overflow-hidden rounded-2xl border border-white/[0.08] bg-surface-800/60"
          style="box-shadow: inset 0 1px 0 rgba(255,255,255,0.05); transition: border-color 200ms var(--ease-out-cubic), transform 200ms var(--ease-out-cubic), box-shadow 200ms var(--ease-out-cubic);"
          onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='rgba(255,255,255,0.16)'"
          onmouseout="this.style.transform='';this.style.borderColor=''"
        >
          <!-- Media -->
          <div class="relative overflow-hidden">
            <img
              src={withBase(project.mediaSlides ? project.mediaSlides[0].path : project.mediaPath)}
              alt={project.mediaAlt}
              class="aspect-video w-full object-cover"
              loading="lazy"
              style={project.mediaFocus ? `object-position: ${project.mediaFocus};` : undefined}
            />
          </div>

          <!-- Content -->
          <div class="flex flex-1 flex-col p-6">
            <div class="mb-3 flex flex-wrap items-center gap-2 text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
              <span>{project.year}</span>
              <span class="h-1 w-1 rounded-full bg-neutral-600" aria-hidden="true"></span>
              <span>{project.role}</span>
            </div>
            <h2 class="font-display text-xl font-extrabold tracking-tight text-white group-hover:text-accent-300" style="transition: color 160ms ease;">{project.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-400">{project.summary}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tags.slice(0, 4).map((tag) => <TagPill label={tag} />)}
            </div>
            <div class="mt-5 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-accent-400 group-hover:gap-2.5" style="transition: gap 160ms ease;">
              View Project
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
