---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TagPill from "@/components/TagPill.astro";
import { projects } from "@/data/projects";
import { withBase } from "@/utils/paths";
---

<BaseLayout
  title="Projects | Christopher Velez"
  description="Case studies in XR, graphics, and interactive systems by Christopher Velez."
  currentPath="/projects"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
      kicker="Projects"
      title="Immersive systems and interactive technology"
      description="Technical execution, design intent, and real-world deployment."
    />
  </section>

  <section class="container flex flex-col pb-24 md:pb-28">
    {
      projects.map((project) => (
        <article id={project.slug} class="case-study reveal">
          <div class="case-grid">
            <div class="flex flex-col gap-8">
              <img
                src={withBase(project.mediaPath)}
                alt={project.mediaAlt}
                class="case-image"
                loading="lazy"
                style={project.mediaFocus ? `object-position: ${project.mediaFocus};` : undefined}
              />
              <div class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-4">
                <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">Tools</p>
                <p class="mt-2 text-sm text-neutral-400">{project.tools.join(" · ")}</p>
              </div>
            </div>
            <div>
              <div class="mb-4 flex flex-wrap items-center gap-3 text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
                <span>{project.year}</span>
                <span class="dot" aria-hidden="true"></span>
                <span>{project.role}</span>
              </div>
              <h2 class="font-display text-3xl font-extrabold tracking-tight text-white md:text-4xl">{project.title}</h2>
              <p class="mt-4 text-neutral-300">{project.summary}</p>
              <p class="mt-4 text-sm text-neutral-200">{project.impact}</p>
              <div class="mt-6 space-y-4 text-sm leading-relaxed text-neutral-400">
                {project.description.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="mt-8 flex flex-wrap gap-2">
                {project.tags.map((tag) => <TagPill label={tag} />)}
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
