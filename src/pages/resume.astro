---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { experiences } from "@/data/experience";
import { education, siteConfig } from "@/data/site";
import { hrefFor } from "@/utils/paths";
---

<BaseLayout
  title="Resume | Christopher Velez"
  description="Resume and qualifications for Christopher Velez."
  currentPath="/resume"
>
  <section class="container py-16 md:py-20">
    <SectionHeading
      kicker="Resume"
      title="Professional snapshot"
      description="A concise web summary with a downloadable PDF for recruiters, labs, and collaborators."
    />
    <div class="reveal mt-8">
      <a href={hrefFor(siteConfig.resumePath)} class="btn" download>
        Download Resume PDF
      </a>
    </div>
  </section>

  <section class="container pb-20">
    <div class="resume-shell reveal">
      <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr]">
        <article>
          <h2 class="font-display text-2xl font-bold text-white">Experience Highlights</h2>
          <div class="mt-6 space-y-6">
            {experiences.map((item) => (
              <section class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-5">
                <h3 class="font-display text-lg font-bold text-white">{item.title}</h3>
                <p class="text-sm text-accent-400">{item.company}</p>
                <p class="mt-1 text-[0.65rem] font-medium uppercase tracking-[0.2em] text-neutral-500">
                  {item.location} · {item.dates}
                </p>
                <ul class="mt-4 space-y-2 text-sm text-neutral-400">
                  {item.highlights.slice(0, 3).map((highlight) => <li class="timeline-bullet">{highlight}</li>)}
                </ul>
              </section>
            ))}
          </div>
        </article>

        <aside class="space-y-6">
          <section class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-5">
            <h2 class="font-display text-lg font-bold text-white">Education</h2>
            <p class="mt-3 text-sm text-neutral-400">{education.university}</p>
            <p class="text-sm text-neutral-400">{education.degree}</p>
            <p class="mt-1 text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-accent-400">{education.graduation}</p>
          </section>
          <section class="rounded-lg border border-white/[0.06] bg-surface-800/40 p-5">
            <h2 class="font-display text-lg font-bold text-white">Contact</h2>
            <p class="mt-3 text-sm text-neutral-400">{siteConfig.email}</p>
            <a class="mt-2 inline-flex text-sm text-accent-400 hover:text-accent-300" href={hrefFor(siteConfig.linkedIn)}>
              LinkedIn
            </a>
            <a class="mt-1 block text-sm text-accent-400 hover:text-accent-300" href={hrefFor(siteConfig.github)}>
              GitHub
            </a>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
