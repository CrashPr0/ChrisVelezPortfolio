---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/paths";
---

<BaseLayout title="404 | Page Not Found" description="The page you were looking for does not exist." currentPath="/">
  <section class="container flex min-h-[60vh] flex-col items-start justify-center py-20">
    <p class="kicker">404</p>
    <h1 class="hero-title max-w-2xl">Oops &mdash; this page flew off the radar!</h1>
    <p class="mt-4 max-w-lg text-white/60">
      This page does not exist or has moved. Head back to the homepage and keep exploring.
    </p>
    <div class="mt-8">
      <a href={withBase("/")} class="btn">Return Home</a>
    </div>
  </section>
</BaseLayout>
