---
import NavBar from "@/components/NavBar.astro";
import Footer from "@/components/Footer.astro";
import { siteConfig } from "@/data/site";
import { withBase, hrefFor } from "@/utils/paths";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  currentPath?: string;
};

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = "/images/placeholders/og-default.svg",
  currentPath = "/"
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImagePath = image.startsWith("http") ? image : withBase(image);
const ogImage = new URL(ogImagePath, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen bg-surface-900 text-slate-100 antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="bg-orb bg-orb-a" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-b" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>
    <NavBar currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script type="module" src={hrefFor("/scripts/site.js")}></script>
  </body>
</html>
